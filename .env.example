# ──────────────────────────────────────────
# Figma 설정
# ──────────────────────────────────────────
# Figma Personal Access Token
# 발급: Figma → 계정 설정 → Security → Personal access tokens
FIGMA_TOKEN=your_figma_personal_access_token_here

# 결과 리포트에 포함될 Figma 파일 ID (선택)
# 예: https://www.figma.com/file/XXXXXX/My-Design 에서 XXXXXX 부분
FIGMA_FILE_ID=

# ──────────────────────────────────────────
# n8n 설정
# ──────────────────────────────────────────
# n8n 웹훅 URL (파이프라인 완료 알림 수신)
# Docker: http://localhost:5678/webhook/design-automation-report
N8N_WEBHOOK_URL=http://localhost:5678/webhook/design-automation-report

# ──────────────────────────────────────────
# 파이프라인 설정
# ──────────────────────────────────────────
# 출력 디렉토리 (기본값: output_assets)
OUTPUT_DIR=output_assets
